{
  "name": "@costscrunch/infrastructure",
  "version": "1.0.0",
  "description": "CostsCrunch — AWS CDK v2 infrastructure",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy:dev": "cdk deploy --context env=dev --require-approval never",
    "deploy:staging": "cdk deploy --context env=staging --require-approval never",
    "deploy:prod": "cdk deploy --context env=prod --require-approval broadening",
    "destroy:dev": "cdk destroy --context env=dev --force",
    "bootstrap": "cdk bootstrap",
    "lint": "eslint . --ext .ts --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --passWithNoTests --coverage",
    "test:localstack": "vitest run --testPathPattern='__tests__/localstack'"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.154.1",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1007.0",
    "@aws-sdk/client-dynamodb": "^3.1007.0",
    "@aws-sdk/client-eventbridge": "^3.1007.0",
    "@aws-sdk/client-iam": "^3.1007.0",
    "@aws-sdk/client-kms": "^3.1007.0",
    "@aws-sdk/client-lambda": "^3.1007.0",
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/client-ses": "^3.1007.0",
    "@aws-sdk/client-sns": "^3.1007.0",
    "@aws-sdk/client-sqs": "^3.1007.0",
    "@aws-sdk/client-ssm": "^3.1007.0",
    "@types/node": "^20.16.1",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "aws-cdk": "^2.154.1",
    "aws-cdk-lib": "^2.154.1",
    "esbuild": "^0.20.2",
    "eslint": "^9.9.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "vitest": "^4.0.18"
  },
  "cdk": {
    "app": "npx ts-node --prefer-ts-exts bin/app.ts",
    "watch": {
      "include": [
        "**"
      ],
      "exclude": [
        "README.md",
        "cdk*.json",
        "**/*.d.ts",
        "**/*.js",
        "tsconfig.json",
        "package*.json",
        "yarn.lock",
        "node_modules",
        "test"
      ]
    },
    "context": {
      "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
      "@aws-cdk/core:enablePartitionLiterals": true,
      "@aws-cdk/aws-events:eventsTargetQueueSameAccount": true
    }
  }
}
