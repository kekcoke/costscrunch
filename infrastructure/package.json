{
  "name": "@costscrunch/infrastructure",
  "version": "1.0.0",
  "description": "CostsCrunch — AWS CDK v2 infrastructure",
  "private": true,

  "scripts": {
    "build":           "tsc --noEmit",
    "typecheck":       "tsc --noEmit",
    "synth":           "cdk synth",
    "diff":            "cdk diff",
    "deploy:dev":      "cdk deploy --context env=dev --require-approval never",
    "deploy:staging":  "cdk deploy --context env=staging --require-approval never",
    "deploy:prod":     "cdk deploy --context env=prod --require-approval broadening",
    "destroy:dev":     "cdk destroy --context env=dev --force",
    "bootstrap":       "cdk bootstrap",
    "lint":            "eslint . --ext .ts --max-warnings 0",
    "test":            "jest --passWithNoTests",
    "test:ci":         "jest --passWithNoTests --coverage --ci"
  },

  "dependencies": {
    "aws-cdk-lib":              "^2.154.1",
    "constructs":               "^10.4.2",
    "source-map-support":       "^0.5.21"
  },

  "devDependencies": {
    "aws-cdk":                  "^2.154.1",

    "@types/node":              "^20.16.1",
    "typescript":               "^5.5.4",
    "ts-node":                  "^10.9.2",

    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser":        "^8.3.0",
    "eslint":                           "^9.9.1",

    "jest":                     "^29.7.0",
    "@types/jest":              "^29.5.13",
    "ts-jest":                  "^29.2.5",
    "aws-cdk-lib":              "^2.154.1"
  },

  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"],
    "collectCoverageFrom": [
      "stacks/**/*.ts",
      "constructs/**/*.ts"
    ]
  },

  "cdk": {
    "app": "npx ts-node --prefer-ts-exts bin/app.ts",
    "watch": {
      "include": ["**"],
      "exclude": [
        "README.md",
        "cdk*.json",
        "**/*.d.ts",
        "**/*.js",
        "tsconfig.json",
        "package*.json",
        "yarn.lock",
        "node_modules",
        "test"
      ]
    },
    "context": {
      "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
      "@aws-cdk/core:enablePartitionLiterals": true,
      "@aws-cdk/aws-events:eventsTargetQueueSameAccount": true
    }
  }
}