{
  "name": "costscrunch",
  "version": "1.0.0",
  "description": "CostsCrunch — Serverless Expense Tracker (Individual / Group / Business)",
  "private": true,
  "workspaces": ["frontend", "backend", "infrastructure"],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "deploy:dev": "cd infrastructure && cdk deploy --context env=dev",
    "deploy:staging": "cd infrastructure && cdk deploy --context env=staging",
    "deploy:prod": "cd infrastructure && cdk deploy --context env=prod --require-approval broadening",
    "synth": "cd infrastructure && cdk synth",
    "diff": "cd infrastructure && cdk diff",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "db:seed": "node scripts/seed-dev.js",
    "load-test": "k6 run tests/load/main.js",
    "dev:opt2": "bash setup/localstack.sh",
    "dev:opt3": "bash setup/localstack-opt3.sh",
    "dev:opt3:clean": "cd infrastructure && docker compose -f docker-compose.localstack.yml down -v && docker system prune -f && cd .. && npm run dev:opt3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.140",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "esbuild": "^0.20.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "ts-jest": "^29.1.2"
  }
}