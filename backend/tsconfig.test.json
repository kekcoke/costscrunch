{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "rootDir": ".",
    "outDir": "./dist-test",
    "composite": true,
    "isolatedModules": true,
    "strict": true,
    "esModuleInterop": true, // Essential for ESM/CJS compatibility
    "skipLibCheck": true,
    "types": [
      "node", 
      "vitest/globals", 
      "@testing-library/jest-dom/vitest"
    ],
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@lambdas/*": ["./src/lambdas/*"]
    }
  },
  "include": [
    "src/**/*.ts", 
    "__tests__/**/*.ts", 
    "vite.config.ts", 
    "__tests__/__config__/**/*.ts",
    "__tests__/__helpers__/**/*.ts",
    "__tests__/__mocks__/**/*.ts",
    "__tests__/setup/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "dist-test"],
  "references": [
    { "path": "./tsconfig.json" }
  ]
}