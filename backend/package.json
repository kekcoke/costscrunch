{
  "name": "@costscrunch/backend",
  "version": "1.0.0",
  "description": "CostsCrunch — Lambda backend (Node.js 20 / TypeScript)",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && npm run bundle",
    "bundle": "node scripts/bundle.mjs",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:ut" : "npx jest --selectProjects unit",
    "test:ig": "npx jest --selectProjects integration",
    "test:ci": "jest --passWithNoTests --coverage --ci --forceExit",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts --max-warnings 0",
    "lint:fix": "eslint . --ext .ts --fix",
    "dev": "npx tsx watch src/server.ts",
    "dev:sam": "sam local start-api --port 4000 --env-vars env.local.json",
    "clean": "rm -rf dist .esbuild"
  },
  "dependencies": {
    "@aws-lambda-powertools/batch": "^2.7.0",
    "@aws-lambda-powertools/idempotency": "^2.7.0",
    "@aws-lambda-powertools/logger": "^2.7.0",
    "@aws-lambda-powertools/metrics": "^2.7.0",
    "@aws-lambda-powertools/parameters": "^2.7.0",
    "@aws-lambda-powertools/tracer": "^2.7.0",
    "@aws-sdk/client-bedrock-runtime": "^3.635.0",
    "@aws-sdk/client-dynamodb": "^3.635.0",
    "@aws-sdk/client-eventbridge": "^3.635.0",
    "@aws-sdk/client-s3": "^3.635.0",
    "@aws-sdk/client-ses": "^3.635.0",
    "@aws-sdk/client-sns": "^3.635.0",
    "@aws-sdk/client-sqs": "^3.635.0",
    "@aws-sdk/client-ssm": "^3.1002.0",
    "@aws-sdk/client-textract": "^3.635.0",
    "@aws-sdk/lib-dynamodb": "^3.635.0",
    "@aws-sdk/s3-presigned-post": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.635.0",
    "@aws-sdk/util-dynamodb": "^3.635.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "body-parser": "^1.20.2",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/aws-lambda": "^8.10.145",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.35",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "aws-sdk-client-mock": "^4.0.2",
    "aws-sdk-client-mock-jest": "^4.0.2",
    "esbuild": "^0.23.1",
    "eslint": "^9.9.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
