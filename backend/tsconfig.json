{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "types": [
      "node", 
      "vitest/globals", 
      "@testing-library/jest-dom/vitest"
    ],
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@lambdas/*": ["./src/lambdas/*"] // Added to match tsconfig.test.json
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "__tests__", "dist-test"]
}