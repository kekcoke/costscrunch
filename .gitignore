# ══════════════════════════════════════════════════════════════════════════════
# CostsCrunch — .gitignore
# Stack: Vite + React · Node.js Lambda · AWS CDK v2 · TypeScript · Monorepo
# ══════════════════════════════════════════════════════════════════════════════


# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz


# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
out/
.output/

# Lambda bundles (esbuild output)
backend/src/lambdas/**/dist/
backend/src/lambdas/**/.esbuild/
backend/dist/

# CDK synthesized output
cdk.out/
infrastructure/cdk.out/

# Frontend Vite build
frontend/dist/
frontend/.vite/


# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
*.d.ts.map

# ─── TypeScript project references (composite builds) ────────────────────────
# Generated by tsconfig.test.json { "composite": true }
backend/dist-test/
backend/tsconfig.test.tsbuildinfo

# ─── Environment & Secrets ────────────────────────────────────────────────────
# NEVER commit .env files — use AWS Secrets Manager / SSM in production
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.staging
.env.staging.local
.env.production
.env.production.local

# AWS credential files (should never be in a project directory, but just in case)
.aws/credentials
.aws/config
aws-exports.js
amplifyconfiguration.json
amplifyconfiguration.ts
aws-exports.ts

# CDK bootstrap context / account IDs
cdk.context.json


# ─── AWS / CDK ────────────────────────────────────────────────────────────────
# CDK asset staging
.cdk.staging/

# SAM local invoke cache
.aws-sam/

# Amplify CLI generated config
amplify/
#amplify/#current-cloud-backend
#amplify/.config/local-*
#amplify/logs/


# ─── Testing & Coverage ───────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
playwright/.cache/


# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ─── OS & Editor ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains / WebStorm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*~

# Emacs
*#
.#*


