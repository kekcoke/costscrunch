# Turbo / NX
.turbo/
.nx/cache/

# Rush
common/temp/

# ESLint cache
.eslintcache

# Prettier cache
.prettiercache

# Stylelint cache
.stylelintcache

# Parcel
.parcel-cache/

# Rollup
.rollup.cache/

# SWC
.swc/

# k6 test outputs
k6-results/
k6-summary*.json

# Semgrep cache
.semgrep/
.semgrepignore


# ─── Docker ───────────────────────────────────────────────────────────────────
# (keep Dockerfile in version control, ignore local overrides)
docker-compose.override.yml


# ─── Lambda layer zips (generated, not committed) ─────────────────────────────
*.zip
layers/


# ─── Terraform (if used alongside CDK) ───────────────────────────────────────
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
.terraform.lock.hcl


# ─── Database seeds / snapshots (local dev only) ──────────────────────────────
scripts/seed-output/
*.dynamo-local/
dynamodb-local-data/


# ─── Generated API clients ────────────────────────────────────────────────────
frontend/src/generated/
backend/shared/generated/


# ─── Storybook ────────────────────────────────────────────────────────────────
storybook-static/


# ─── Temporary files ──────────────────────────────────────────────────────────
tmp/
temp/
.tmp/
*.tmp
*.bak
*.orig

