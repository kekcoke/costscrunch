{
  // ─── Vitest Extension Configuration ─────────────────────────────────────────
  "vitest.enable": true,
  "vitest.commandLine": "npx vitest",
  "vitest.workspaceConfig": "${workspaceFolder}/.vscode/vitest.workspace.ts",

  // Auto-detect test files
  "vitest.include": [
    "**/__tests__/**/*.test.ts",
    "**/__tests__/**/*.test.tsx",
    "**/*.test.ts",
    "**/*.test.tsx"
  ],

  // Environment variables for all test projects
  "vitest.nodeEnv": {
    "NODE_ENV": "test"
  },

  // ─── Test Explorer Configuration ─────────────────────────────────────────────
  "testExplorer.useNativeTesting": false,

  // ─── File Associations ───────────────────────────────────────────────────────
  "files.associations": {
    "*.test.ts": "typescript",
    "*.test.tsx": "typescriptreact",
    "*.spec.ts": "typescript",
    "*.spec.tsx": "typescriptreact",
    "vitest.workspace.ts": "typescript",
    "vite.config.ts": "typescript"
  },

  // ─── TypeScript Configuration ────────────────────────────────────────────────
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,

  // ─── Monorepo Settings ───────────────────────────────────────────────────────
  // Search exclude patterns for monorepo
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.esbuild": true,
    "**/coverage": true
  },

  // File watcher excludes for performance
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.esbuild/**": true,
    "**/coverage/**": true
  },

  // ─── Editor Settings ─────────────────────────────────────────────────────────
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  // ─── Workbench Settings ──────────────────────────────────────────────────────
  "workbench.editorAssociations": {
    "*.test.ts": "default",
    "*.test.tsx": "default"
  }
}
