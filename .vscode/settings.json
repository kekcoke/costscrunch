{
  // ─── Vitest Extension Configuration ─────────────────────────────────────────
  "vitest.enable": true,
  "vitest.commandLine": "node_modules/.bin/vitest",
  "vitest.root": "${workspaceFolder}",
  "vitest.workspaceConfig": "vitest.workspace.ts",
  "vitest.nodeRuntime": "/opt/homebrew/bin/node",
  "vitest.env": {
    "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
  },
  "vitest.nodeEnv": {
    "NODE_ENV": "test"
  },

  // ─── Test Explorer Configuration ─────────────────────────────────────────────
  "testExplorer.useNativeTesting": true,

  // ─── File Associations ───────────────────────────────────────────────────────
  "files.associations": {
    "*.test.ts": "typescript",
    "*.test.tsx": "typescriptreact",
    "*.spec.ts": "typescript",
    "*.spec.tsx": "typescriptreact",
    "vitest.workspace.ts": "typescript",
    "vite.config.ts": "typescript"
  },

  // ─── TypeScript Configuration ────────────────────────────────────────────────
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,

  // ─── Monorepo Settings ───────────────────────────────────────────────────────
  // Search exclude patterns for monorepo
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.esbuild": true,
    "**/coverage": true
  },

  // File watcher excludes for performance
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.esbuild/**": true,
    "**/coverage/**": true
  },

  // ─── Editor Settings ─────────────────────────────────────────────────────────
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  // ─── Workbench Settings ──────────────────────────────────────────────────────
  "workbench.editorAssociations": {
    "*.test.ts": "default",
    "*.test.tsx": "default"
  },
  "cSpell.words": [
    "localstack"
  ],
  // ─── YAML Settings ──────────────────────────────────────────────────────
  "yaml.customTags": [
    "!Ref scalar",
    "!GetAtt scalar",
    "!FindInMap scalar",
    "!Sub scalar",
    "!If scalar",
    "!Equals scalar",
    "!Or scalar",
    "!And scalar",
    "!Not scalar",
    "!NoValue scalar",
    "!Base64 scalar",
    "!Cidr scalar"
  ]
  
}
